# Copy this file to .env.local for local development.
# .env.local is ignored by Git and should contain real secrets.

# Optional. When absent or blank, feedback is stored in memory for the current server process.
DATABASE_URL="postgres://day_planner:day_planner@localhost:5433/day_planner"

# Optional. When absent or blank, the app uses a simple fallback plan summary.
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-2.0-flash"
GEMINI_GROUNDED_MODEL="gemini-2.5-flash-lite"

# Optional. Enables live ticketed events through Ticketmaster Discovery API.
TICKETMASTER_API_KEY=""
